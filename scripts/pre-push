#!/usr/bin/env bash
# Pre-push hook — runs lint, type check, and tests before push.
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Skip:    git push --no-verify
set -euo pipefail

echo "Running pre-push checks..."
echo ""

# 1. Ruff lint
echo "[1/3] Ruff check..."
ruff check .
ruff format --check .

# 2. Mypy type check (warn only — not blocking until type stubs are complete)
echo "[2/3] Mypy type check (non-blocking)..."
mypy core/ cli/ --ignore-missing-imports || echo "  mypy found issues (non-blocking, see above)"

# 3. Pytest (skip if no tests found)
echo "[3/3] Running tests..."
pytest -q 2>/dev/null || echo "  No tests found or pytest not available (skipping)"

echo ""
echo "All pre-push checks passed."
