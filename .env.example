# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://open_intern:open_intern@localhost:5556/open_intern

# Encryption key for DB secrets (required)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# E2B sandbox (optional, shared infra — for isolated code execution)
# E2B_API_KEY=e2b_xxx

# Cloudflare R2 backup (optional — for sandbox file persistence)
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET=open-intern-backups

# Dashboard auth (required for multi-user)
# API_SECRET_KEY=xxx
# ADMIN_EMAIL=admin@your-company.com

# CORS origins (comma-separated, optional)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Sentry error tracking — backend (optional — no data sent when DSN is empty)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry error tracking — frontend / Next.js dashboard (separate DSN)
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Telegram webhook (required if running telegram platform)
# WEBHOOK_BASE_URL=https://your-domain.com
