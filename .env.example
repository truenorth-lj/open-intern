# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://open_intern:open_intern@localhost:5556/open_intern

# Encryption key for DB secrets (required)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# E2B sandbox (optional, shared infra — for isolated code execution)
# E2B_API_KEY=e2b_xxx

# Dashboard auth (required for multi-user)
# API_SECRET_KEY=xxx
# ADMIN_EMAIL=admin@your-company.com

# CORS origins (comma-separated, optional)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Telegram webhook (required if running telegram platform)
# WEBHOOK_BASE_URL=https://your-domain.com
