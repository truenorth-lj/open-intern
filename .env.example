# LLM API Keys (set the one matching your config)
ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# MINIMAX_API_KEY=xxx

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://open_intern:open_intern@localhost:5556/open_intern

# Platform tokens (optional, depending on platform)
# TELEGRAM_BOT_TOKEN=xxx
# DISCORD_BOT_TOKEN=xxx

# Dashboard auth (required for multi-user)
# DASHBOARD_PASSWORD=your-admin-password
# AUTH_SECRET=generate-with-openssl-rand-hex-32
# ADMIN_EMAIL=admin@your-company.com

# API authentication (optional)
# API_SECRET_KEY=xxx

# CORS origins (comma-separated, optional)
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com
